# Copy to .env for local dev, or set these as Variables in Railway.

# PostgreSQL connection string.
#  - Railway: reference the Postgres plugin, e.g. ${{Postgres.DATABASE_URL}}
#  - Local dev: postgresql://postgres@localhost:5433/sirevents?schema=public
DATABASE_URL=

# Display currency (ISO 4217). Public (compiled into the client bundle).
NEXT_PUBLIC_CURRENCY=EUR

# Cloudflare R2 (S3-compatible) image storage. Omit to disable uploads.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional: public bucket URL (custom domain / r2.dev). If unset, images are
# served through the app's authenticated /api/files proxy.
R2_PUBLIC_BASE_URL=

# Used only by `npm run create:platform-admin` to bootstrap the first admin.
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=
PLATFORM_ADMIN_NAME=Platform Owner
