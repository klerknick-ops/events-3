// Event planning platform — multi-tenant relational schema (PostgreSQL).
//
// Tenancy: every business-data row belongs to exactly one Organization
// (tenant). Queries are always scoped by the signed-in user's organizationId
// (see lib/tenant.ts). Platform admins (isPlatformAdmin) sit above all orgs and
// provision them. Enum-like fields are String + TS unions (lib/enums.ts). Money
// is Float, rounded centrally in lib/money.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Tenancy ----------

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique // stable identifier (future subdomains)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  companies     Company[]
  contacts      Contact[]
  spaces        BookableSpace[]
  products      Product[]
  roomTypes     HotelRoomType[]
  taskTemplates TaskTemplate[]
  templates     EventTemplate[]
  events        Event[]
  settings      Setting[]
  activities    ActivityLog[]
  paymentTerms  PaymentTerms[]
  generatedDocs GeneratedDocument[]
  emails        EmailMessage[]
  tasks         Task[]
  notificationRules NotificationRule[]
  budgets       Budget[]
  statusWeights StatusWeight[]
}

// ---------- Users & auth ----------

model User {
  id              String        @id @default(cuid())
  email           String        @unique
  name            String
  passwordHash    String
  role            String        @default("STAFF") // ADMIN | MANAGER | STAFF
  active          Boolean       @default(true)
  isPlatformAdmin Boolean       @default(false) // provisions orgs; not org-scoped
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  sessions       Session[]
  activities     ActivityLog[]
  notes          EventNote[]
  ownedEmails    EmailMessage[] @relation("EmailOwner")
  assignedEvents Event[]        @relation("EventAssignee")
  assignedTasks  Task[]         @relation("TaskAssignee")
  taskRules      TaskTemplate[] @relation("TaskRuleAssignee")

  @@index([organizationId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ---------- Clients ----------

model Company {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  phone          String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  contacts Contact[]

  @@index([organizationId])
}

model Contact {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  email          String?
  phone          String?
  notes          String?
  companyId      String?
  company        Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  events Event[]
  emails EmailMessage[]

  @@index([organizationId])
  @@index([companyId])
}

// ---------- Building blocks (Configuration) ----------

model BookableSpace {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  capacity       Int?
  color          String       @default("#6366f1")
  sortOrder      Int          @default(0)
  archived       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  timeSlots     EventTimeSlot[]
  templateSlots TemplateSlot[]
  setups        Setup[]
  notificationRuleSpaces NotificationRuleSpace[]

  @@index([organizationId])
}

// Room layout / "opstelling" available for a specific space (Theatre, U-shape,
// Banquet rounds, Boardroom…). Setups are configured per BookableSpace.
model Setup {
  id        String        @id @default(cuid())
  spaceId   String
  space     BookableSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int           @default(0)
  archived  Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  rules     SetupRule[]
  timeSlots EventTimeSlot[]
  notificationRules NotificationRule[]

  @@index([spaceId])
}

// Threshold rule: when a slot's person count >= minPersons, apply these layout
// attributes (e.g. 2 tables at 18+, head tables at 32+).
model SetupRule {
  id         String  @id @default(cuid())
  setupId    String
  setup      Setup   @relation(fields: [setupId], references: [id], onDelete: Cascade)
  minPersons Int
  tableCount Int? // resulting number of tables at/above this threshold
  headTables Boolean @default(false) // add head/end tables
  note       String? // free-text layout note
  sortOrder  Int     @default(0)

  @@index([setupId])
}

model Product {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  imageUrl       String?
  priceNet       Float        @default(0)
  taxRate        Float        @default(0) // percentage, e.g. 21 for 21%
  productType    String       @default("EVENT") // EVENT (qty 1) | GUEST (qty from slot person count)
  archived       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  eventProducts    EventProduct[]
  templateProducts TemplateProduct[]
  notificationRules NotificationRule[]

  @@index([organizationId])
}

// Hotel room type — structurally similar to Product but kept distinct. Has an
// inventory count (number of physical rooms of this type) for per-night
// availability checks, and is booked by date range rather than a time slot.
model HotelRoomType {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  imageUrl       String?
  priceNet       Float        @default(0) // price per night, net
  taxRate        Float        @default(0)
  inventory      Int          @default(1) // total rooms of this type
  archived       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  bookings EventRoomBooking[]

  @@index([organizationId])
}

// Reusable payment-terms preset (deposit % + balance arrangement), selectable
// when creating an event and insertable into documents.
model PaymentTerms {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  depositPercent Int? // e.g. 50
  body           String // full terms text used in documents
  sortOrder      Int          @default(0)
  archived       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  events Event[]

  @@index([organizationId])
}

// Per-organization settings (cancellation policy, doc templates, …).
model Setting {
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  key            String
  value          String
  updatedAt      DateTime     @updatedAt

  @@id([organizationId, key])
}

// Reusable deadline rule, referenced by event templates.
model TaskTemplate {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title           String
  defaultAssignee String?      // legacy free-text (superseded by assignedUserId)
  assignedUserId  String?
  assignedUser    User?        @relation("TaskRuleAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)

  // Trigger type: how/when this rule generates a task.
  triggerType     String       @default("RELATIVE") // RELATIVE | RECURRING | ACTION

  // RELATIVE: deadline = event date (or creation) +/- offsetDays.
  offsetDays      Int          @default(0)
  basis           String       @default("BEFORE_EVENT") // BEFORE_EVENT | BEFORE_CREATION

  // RECURRING: WEEKLY (recurrenceWeekday) or MONTHLY (recurrenceDay, or
  // recurrenceOrdinal+recurrenceWeekday for "2nd Monday").
  recurrenceFreq    String?    // WEEKLY | MONTHLY
  recurrenceWeekday Int?       // 0 (Sun) .. 6 (Sat)
  recurrenceDay     Int?       // day-of-month 1..31
  recurrenceOrdinal Int?       // 1..5, -1 = last (ordinal weekday)

  // ACTION: trigger on an inbox or status-change event.
  actionType      String?      // EMAIL_RECEIVED | EMAIL_SENT | STATUS_CHANGE
  actionStatus    String?      // target status for STATUS_CHANGE
  leadDays        Int          @default(7) // deadline = trigger date + leadDays (keeps required-deadline rule)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  templateTasks TemplateTask[]

  @@index([organizationId])
}

model EventTemplate {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  archived       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  slots    TemplateSlot[]
  products TemplateProduct[]
  tasks    TemplateTask[]
  events   Event[]

  @@index([organizationId])
}

// Default time-slot structure for a template (suggested space + time + duration).
model TemplateSlot {
  id         String         @id @default(cuid())
  templateId String
  template   EventTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  spaceId    String?
  space      BookableSpace? @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  label      String?
  startTime  String         @default("12:00") // HH:mm on the event day
  durationMin Int           @default(120)
  dayOffset  Int            @default(0) // day relative to the event's first day
  sortOrder  Int            @default(0)

  products TemplateProduct[]

  @@index([templateId])
}

// Default product attached to a template. Products now live under a template
// time slot (templateSlotId); rows with a null slot are legacy template-level
// defaults kept for back-compat.
model TemplateProduct {
  id             String        @id @default(cuid())
  templateId     String
  template       EventTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateSlotId String?
  templateSlot   TemplateSlot? @relation(fields: [templateSlotId], references: [id], onDelete: Cascade)
  productId      String
  product        Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity       Int           @default(1)

  @@index([templateId])
  @@index([templateSlotId])
}

model TemplateTask {
  id             String        @id @default(cuid())
  templateId     String
  template       EventTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  taskTemplateId String
  taskTemplate   TaskTemplate  @relation(fields: [taskTemplateId], references: [id], onDelete: Cascade)
  sortOrder      Int           @default(0)

  @@index([templateId])
}

// ---------- Events ----------

model Event {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  status         String         @default("INQUIRY") // INQUIRY | TENTATIVE | CONFIRMED | COMPLETED | CANCELLED
  notes          String?
  contactId      String
  contact        Contact        @relation(fields: [contactId], references: [id], onDelete: Restrict)
  templateId     String?
  template       EventTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  paymentTermsId String?
  paymentTerms   PaymentTerms?  @relation(fields: [paymentTermsId], references: [id], onDelete: SetNull)
  assignedUserId String?
  assignedUser   User?          @relation("EventAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  days         EventDay[]
  timeSlots    EventTimeSlot[]
  products     EventProduct[]
  roomBookings EventRoomBooking[]
  tasks        Task[]
  eventNotes   EventNote[]
  activities   ActivityLog[]
  generatedDocs GeneratedDocument[]
  emails       EmailMessage[]

  @@index([organizationId])
  @@index([contactId])
  @@index([status])
}

// A saved version of a generated document (Function Sheet / Proposal /
// Confirmation / Pro Forma). The JSON snapshot captures the line-item data used
// to produce it, so a later version can be diffed against the previous one to
// highlight what changed.
model GeneratedDocument {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventId        String
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  docType        String       // function_sheet | proposal | confirmation | proforma
  version        Int
  snapshot       Json
  generatedAt    DateTime     @default(now())

  @@unique([eventId, docType, version])
  @@index([organizationId])
  @@index([eventId, docType])
}

// An email synced from / sent through the connected Microsoft 365 mailbox.
// Inbound mail whose sender matches a Contact-with-event is auto-linked to that
// event (Client Mail); everything else lands in Leads & Vendors where it can be
// labelled Vendor/Supplier and manually linked to an event.
model EmailMessage {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  graphId        String?      // Microsoft Graph message id (null for not-yet-synced local sends)
  conversationId String?      // Graph conversation/thread id
  direction      String       // INBOUND | OUTBOUND
  fromAddress    String
  fromName       String?
  toAddresses    String       // comma-separated recipients
  ccAddresses    String?      // comma-separated CC recipients
  subject        String
  bodyPreview    String?
  body           String       @default("")
  bodyIsHtml     Boolean      @default(true)
  receivedAt     DateTime
  isRead         Boolean      @default(false)
  label          String?      // VENDOR | SUPPLIER (null = lead / untagged)
  contactId      String?
  contact        Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  eventId        String?
  event          Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  autoMatched    Boolean      @default(false) // event link came from a contact match
  ownerId        String?      // manually-assigned owner for lead emails (no event)
  owner          User?        @relation("EmailOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  deletedAt      DateTime?    // soft delete — hidden from views, kept for audit/recovery
  archivedAt     DateTime?    // archived — hidden from default view, kept in "Archived" folder
  createdAt      DateTime     @default(now())

  attachments EmailAttachment[]
  tasks       Task[]

  @@unique([organizationId, graphId])
  @@index([organizationId])
  @@index([eventId])
  @@index([contactId])
}

// A file attached to an email (sent or received). The bytes live in object
// storage (R2 / dev uploads) keyed by storageKey; served via /api/files.
model EmailAttachment {
  id             String       @id @default(cuid())
  emailMessageId String
  email          EmailMessage @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)
  filename       String
  contentType    String       @default("application/octet-stream")
  size           Int          @default(0)
  storageKey     String?      // object-storage key (null if only a Graph reference)
  graphAttachmentId String?   // Graph attachment id (for lazy fetch from M365)
  isInline       Boolean      @default(false)
  contentId      String?      // cid: for inline images
  createdAt      DateTime     @default(now())

  @@index([emailMessageId])
}

// A single calendar day within an event. Single-day events have exactly one
// EventDay; multi-day events have several, each with independent slots/products.
model EventDay {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  date      DateTime // local midnight of the day
  label     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timeSlots EventTimeSlot[]
  products  EventProduct[]

  @@index([eventId])
}

model EventTimeSlot {
  id        String        @id @default(cuid())
  eventId   String
  event     Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  dayId     String?
  day       EventDay?     @relation(fields: [dayId], references: [id], onDelete: Cascade)
  spaceId   String
  space     BookableSpace @relation(fields: [spaceId], references: [id], onDelete: Restrict)
  label     String?
  startsAt  DateTime
  endsAt    DateTime
  sortOrder Int           @default(0)

  // Person count governs per-person product quantities + setup auto-rules.
  personCount Int     @default(0)
  // Chosen room setup + its (possibly auto-applied, possibly overridden) layout.
  setupId         String?
  setup           Setup?  @relation(fields: [setupId], references: [id], onDelete: SetNull)
  setupTableCount Int?
  setupHeadTables Boolean @default(false)
  setupManual     Boolean @default(false) // true once the user overrides auto-rules

  // Ops-facing note shown on this slot in generated documents.
  notes String?

  products EventProduct[]

  @@index([eventId])
  @@index([dayId])
  @@index([setupId])
  @@index([spaceId, startsAt])
}

// Event <-> Product join with quantity and per-line price/tax overrides.
// Optionally scoped to a specific time slot.
model EventProduct {
  id                   String         @id @default(cuid())
  eventId              String
  event                Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  dayId                String?
  day                  EventDay?      @relation(fields: [dayId], references: [id], onDelete: Cascade)
  slotId               String?
  slot                 EventTimeSlot? @relation(fields: [slotId], references: [id], onDelete: SetNull)
  productId            String
  product              Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity             Int            @default(1)
  // Per-line overrides for this booking only (master Product unchanged).
  nameOverride         String?
  unitPriceNetOverride Float?
  taxRateOverride      Float?
  // Ops-facing note shown on this product line in generated documents.
  notes                String?

  @@index([eventId])
  @@index([dayId])
  @@index([slotId])
}

model Task {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Event is optional: a task can be a standalone lead follow-up (e.g. created
  // from an email before any event exists).
  eventId        String?
  event          Event?        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  // Optional source email. SetNull so the task survives if the email is deleted.
  emailMessageId String?
  emailMessage   EmailMessage? @relation(fields: [emailMessageId], references: [id], onDelete: SetNull)
  title          String
  assignee       String?       // legacy free-text (superseded by assignedUserId)
  assignedUserId String?
  assignedUser   User?         @relation("TaskAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  dueDate        DateTime?
  completed      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
  @@index([eventId])
  @@index([emailMessageId])
  @@index([assignedUserId])
  @@index([dueDate])
}

// Hotel room booking on an event: a quantity of a room type over a date range
// (check-in → check-out). Conflict checks compare nightly demand to inventory.
model EventRoomBooking {
  id         String        @id @default(cuid())
  eventId    String
  event      Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  roomTypeId String
  roomType   HotelRoomType @relation(fields: [roomTypeId], references: [id], onDelete: Restrict)
  quantity   Int           @default(1)
  checkIn    DateTime
  checkOut   DateTime
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([eventId])
  @@index([roomTypeId, checkIn])
}

// ---------- Notes & activity ----------

// Manually written, timestamped context notes (distinct from the activity log).
model EventNote {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  body      String
  createdAt DateTime @default(now())

  @@index([eventId])
}

// System-generated record of meaningful changes (who / what / when).
model ActivityLog {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventId        String?
  event          Event?        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  action         String // e.g. EVENT_CREATED, STATUS_CHANGED, PRODUCT_ADDED
  summary        String // human-readable description
  createdAt      DateTime      @default(now())

  @@index([organizationId])
  @@index([eventId])
  @@index([userId])
  @@index([createdAt])
}

// ---------- Notification / constraint rules ----------

// A planning constraint or reminder surfaced (non-blocking) while a planner
// selects a matching space, product or setup — e.g. "garden may not be entered
// before 10:00" or "if the garden is booked, include 2 hotel rooms".
model NotificationRule {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  targetType     String       // SPACE | PRODUCT | SETUP
  message        String       // warning/instruction shown to staff
  minPersons     Int?         // optional person-count threshold condition
  productId      String?      // PRODUCT target
  product        Product?     @relation(fields: [productId], references: [id], onDelete: Cascade)
  setupId        String?      // SETUP target
  setup          Setup?       @relation(fields: [setupId], references: [id], onDelete: Cascade)
  active         Boolean      @default(true)
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  spaces NotificationRuleSpace[]

  @@index([organizationId])
}

// Applicable space(s) for a notification rule (for SPACE target these are the
// targeted spaces; for PRODUCT/SETUP they scope where the rule applies).
model NotificationRuleSpace {
  id      String           @id @default(cuid())
  ruleId  String
  rule    NotificationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  spaceId String
  space   BookableSpace    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([ruleId, spaceId])
  @@index([ruleId])
  @@index([spaceId])
}

// ---------- Budgets & revenue weighting ----------

// Monthly revenue target (YYYY-MM).
model Budget {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  month          String       // "YYYY-MM"
  amount         Float        @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, month])
  @@index([organizationId])
}

// Admin-configurable revenue weight per event status, used for OTB ("on the
// books") weighted-revenue calculations (e.g. INQUIRY 50%, CONFIRMED 100%).
model StatusWeight {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  status         String       // INQUIRY | TENTATIVE | CONFIRMED | COMPLETED | CANCELLED
  weightPercent  Int          @default(100)
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, status])
  @@index([organizationId])
}
